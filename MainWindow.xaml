<Window x:Class="HFFS3CustomLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HFFS3CustomLauncher" d:DataContext="{d:DesignInstance Type=local:MainLogic}"
        mc:Ignorable="d"
        Title="{DynamicResource The_Sims_3_Custom_Launcher_by_Hundefreund}" Height="660" Width="865" MinHeight="600" MinWidth="800" WindowStyle="None" AllowsTransparency="True" Background="#01FFFFFF" Closing="OnCloseWindow" ResizeMode="CanMinimize">

    <Window.Resources>
        <Style TargetType="ToolTip" BasedOn="{StaticResource CustomTooltip}" />
    </Window.Resources>
    <Grid x:Name="OutmostGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="10" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="10" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="10" />
        </Grid.RowDefinitions>

        <Border Grid.Column="1" Grid.Row="1" BorderBrush="Black" BorderThickness="1" MouseLeftButtonDown="OnMoveWindow" MouseEnter="General_OnMouseEnter">
            <Border.Background>
                <ImageBrush ImageSource="Images/bg.jpg"/>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect ShadowDepth="4" BlurRadius="5" Direction="310" Opacity="0.5" />
            </Border.Effect>
            <Border.Style>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="Padding" Value="5"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="CornerRadius" Value="8"/>
                    <Setter Property="BorderThickness" Value="1" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Path=IsWindowsXP}" Value="True">
                            <Setter Property="Margin" Value="-10"/>
                            <Setter Property="CornerRadius" Value="0" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Path=IsMaximized}" Value="True">
                            <Setter Property="Margin" Value="-10"/>
                            <Setter Property="CornerRadius" Value="0" />
                            <Setter Property="BorderThickness" Value="0" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Window}}" Value="Maximized">
                            <Setter Property="Margin" Value="-10"/>
                            <Setter Property="CornerRadius" Value="0" />
                            <Setter Property="BorderThickness" Value="0" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel>
                <Border DockPanel.Dock="Top" Margin="3,0,3,5" BorderBrush="Black" BorderThickness="1" CornerRadius="4" Background="{StaticResource CustomBackgroundGrey_Colour}" Height="30" VerticalAlignment="Top" MouseLeftButtonDown="OnMoveWindow" MouseEnter="General_OnMouseEnter" MouseMove="TopPanel_OnMouseMove">
                    <Grid>
                        <Button x:Name="button_CloseLeft" Content="x" ToolTip="{DynamicResource Close}" Click="OnCloseWindow">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource CustomButtonTopPanelLeftSide}">
                                    <Setter Property="Margin" Value="4,4,0,0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Margin" Value="4,5,0,0"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button x:Name="button_MinimizeLeft" Content="__" ToolTip="{DynamicResource Minimize}" Click="OnMinimizeWindow">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource CustomButtonTopPanelLeftSide}">
                                    <Setter Property="Margin" Value="30,4,0,0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Margin" Value="30,5,0,0"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button x:Name="button_MaximizeLeft" Content="o" Click="OnMaximizeWindow">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource CustomButtonTopPanelLeftSide}">
                                    <Setter Property="Margin" Value="56,4,0,0"/>
                                    <Setter Property="ToolTip" Value="{DynamicResource Maximize}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Margin" Value="56,5,0,0" />
                                        </Trigger>
                                        <DataTrigger Binding="{Binding Path=IsMaximized}" Value="True">
                                            <Setter Property="ToolTip" Value="{DynamicResource Restore}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Window}}" Value="Maximized">
                                            <Setter Property="ToolTip" Value="{DynamicResource Restore}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Label Content="{DynamicResource The_Sims_3_Custom_Launcher_by_Hundefreund}" FontSize="15" FontWeight="DemiBold" HorizontalAlignment="Center" Foreground="White" />
                        <Button x:Name="button_Minimize" Content="__" ToolTip="{DynamicResource Minimize}" Click="OnMinimizeWindow">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource CustomButtonTopPanel}">
                                    <Setter Property="Margin" Value="0,4,56,0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Margin" Value="0,5,56,0"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button x:Name="button_Maximize" Content="o" Click="OnMaximizeWindow">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource CustomButtonTopPanel}">
                                    <Setter Property="Margin" Value="0,4,30,0"/>
                                    <Setter Property="ToolTip" Value="{DynamicResource Maximize}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Margin" Value="0,5,30,0" />
                                        </Trigger>
                                        <DataTrigger Binding="{Binding Path=IsMaximized}" Value="True">
                                            <Setter Property="ToolTip" Value="{DynamicResource Restore}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Window}}" Value="Maximized">
                                            <Setter Property="ToolTip" Value="{DynamicResource Restore}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button x:Name="button_Close" Content="x" ToolTip="{DynamicResource Close}" Click="OnCloseWindow">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource CustomButtonTopPanel}">
                                    <Setter Property="Margin" Value="0,4,4,0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Margin" Value="0,5,4,0"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <Rectangle x:Name="TabItemHeaderFillingHeight" DockPanel.Dock="Left" Margin="0,277,0,59" Visibility="Hidden" Width="0" />

                <TabControl x:Name="CentralTabControl" TabStripPlacement="Left" Background="Transparent" BorderThickness="0" BorderBrush="Transparent" Margin="0,0,-18,-18" MouseLeftButtonDown="OnMoveWindow" MouseEnter="General_OnMouseEnter" SelectedIndex="{Binding State_SelectedMenu}">
                    <TabItem Focusable="False">
                        <TabItem.Style>
                            <Style TargetType="{x:Type TabItem}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type TabItem}">
                                            <Border BorderThickness="1,1,1,0" BorderBrush="Black" Background="Transparent" CornerRadius="12,12,0,0">
                                                <Border Name="Border" Style="{StaticResource CustomBorderTabItemTop}" MouseLeftButtonDown="OnMoveWindow">
                                                    <ContentPresenter x:Name="ContentSite" VerticalAlignment="Top" HorizontalAlignment="Center" ContentSource="Header" Margin="0" RecognizesAccessKey="True"/>
                                                </Border>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabItem.Style>
                        <TabItem.Header>
                            <Image Source="Images/CustomLauncherLogo.jpg" Margin="0" VerticalAlignment="Top" Height="138" />
                        </TabItem.Header>
                    </TabItem>
                    <TabItem DataContext="{Binding DownloadsTool}">
                        <TabItem.Style>
                            <Style TargetType="{x:Type TabItem}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type TabItem}">
                                            <Border BorderThickness="1,0" BorderBrush="Black" Background="Transparent">
                                                <Border Name="Border" Style="{StaticResource CustomBorderTabItemMiddle}" MouseLeftButtonDown="OnMoveWindow">
                                                    <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="0" RecognizesAccessKey="True"/>
                                                </Border>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabItem.Style>
                        <TabItem.Header>
                            <Button x:Name="button_Downloads" Click="OnPanelButtonClick">
                                <Button.Style>
                                    <Style TargetType="{x:Type Button}" BasedOn="{StaticResource CustomButtonTabItemHeader}">
                                        <Setter Property="ToolTip" Value="{DynamicResource Downloads}" />
                                    </Style>
                                </Button.Style>
                                <ContentPresenter>
                                    <ContentPresenter.Content>
                                        <Grid Width="170">
                                            <Label Margin="0,0,0,0" Height="36" Content="{DynamicResource Downloads}" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource CustomForegroundDarkBlue_Colour}" />
                                            <Image Margin="0,0,2,0" HorizontalAlignment="Right" Source="Images/CustomExclamationMarkIcon.png">
                                                <Image.Style>
                                                    <Style TargetType="{x:Type Image}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Setter Property="Width" Value="20" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding GotUpdate}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                        </Grid>
                                    </ContentPresenter.Content>
                                </ContentPresenter>
                            </Button>
                        </TabItem.Header>

                        <Border BorderThickness="1" BorderBrush="Black" Margin="10,0,18,18" CornerRadius="12" Background="Transparent">
                            <Border Style="{StaticResource CustomBorderTabItemContent}">

                                <Border BorderBrush="Transparent" BorderThickness="0" CornerRadius="8" MouseEnter="General_OnMouseEnter" MouseLeftButtonDown="PreventAnyAction" Background="{StaticResource CustomBackgroundLightBlue_Colour}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="42" />
                                            <RowDefinition Height="7" />
                                            <RowDefinition Height="50" />
                                            <RowDefinition Height="1*" />
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">
                                            <Label Content="{DynamicResource Downloads}" Style="{StaticResource CustomLabelMenuTitle}" />
                                            <Button Visibility="Hidden" x:Name="button_Help" Click="OnHelp" Style="{StaticResource CustomButtonHelp}" />
                                        </Grid>
                                        <Border Grid.Row="1" Style="{StaticResource CustomBorderUnderline}" />
                                        <Grid Grid.Row="2">
                                            <Label FontSize="15" Foreground="{StaticResource CustomForegroundDarkBlue_Colour}" Height="35" VerticalAlignment="Top">
                                                <Label.Style>
                                                    <Style TargetType="{x:Type Label}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Setter Property="Margin" Value="0,-5,0,0" />
                                                        <Setter Property="Content" Value="{DynamicResource Downloads_Description}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Path=IsLoading}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Label.Style>
                                            </Label>
                                            <Label FontSize="15" Foreground="{StaticResource CustomForegroundDarkBlue_Colour}" Height="35" VerticalAlignment="Bottom">
                                                <Label.Style>
                                                    <Style TargetType="{x:Type Label}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Setter Property="Margin" Value="0,0,0,0" />
                                                        <Setter Property="Content" Value="{Binding FileLogicLoadOutput}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Path=IsLoading}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Label.Style>
                                            </Label>
                                            <Label FontSize="15" Foreground="{StaticResource CustomForegroundDarkBlue_Colour}" Height="35" VerticalAlignment="Top">
                                                <Label.Style>
                                                    <Style TargetType="{x:Type Label}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Setter Property="Margin" Value="0,-5,0,0" />
                                                        <Setter Property="Content" Value="{DynamicResource Processing}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Path=IsLoading}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Label.Style>
                                            </Label>
                                            <ProgressBar IsIndeterminate="False" VerticalAlignment="Bottom" HorizontalAlignment="Left" Width="500" Height="14" Margin="10,0,0,13" BorderBrush="Black" BorderThickness="0">
                                                <ProgressBar.Style>
                                                    <Style TargetType="{x:Type ProgressBar}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Setter Property="Background" Value="{StaticResource CustomProgressBar_OuterColour}" />
                                                        <Setter Property="Foreground" Value="{StaticResource CustomProgressBar_InnerColour}" />
                                                        <Setter Property="Maximum" Value="{Binding AllFilesCount}" />
                                                        <Setter Property="Value" Value="{Binding LoadedFilesCount}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Path=IsLoading}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ProgressBar.Style>
                                            </ProgressBar>
                                            <Border Background="Transparent" VerticalAlignment="Bottom" HorizontalAlignment="Left" Width="516" Height="30" Margin="2,0,0,5" BorderBrush="{StaticResource CustomBackgroundLightBlue_SolidColour}" BorderThickness="8,0" CornerRadius="65">
                                                <Border.Style>
                                                    <Style TargetType="{x:Type Border}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Path=IsLoading}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Border Background="Transparent" VerticalAlignment="Bottom" HorizontalAlignment="Left" Width="500" Height="17" Margin="0,0,0,5" BorderBrush="#88000000" BorderThickness="1,1,2,3" CornerRadius="10" />
                                            </Border>
                                        </Grid>
                                        <Border Grid.Row="3" BorderBrush="{StaticResource CustomForegroundDarkBlue_Colour}" BorderThickness="1" Margin="0,30,0,5" Background="{StaticResource CustomBackgroundVeryLightBlue_Colour}" CornerRadius="8">
                                            <Grid>
                                                <Button x:Name="button_FilterAll" Click="OnFilter" FontSize="30">
                                                    <Button.Style>
                                                        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource CustomButtonFilter}">
                                                            <Setter Property="Margin" Value="10,-30,0,0" />
                                                            <Setter Property="ToolTip" Value="{DynamicResource All}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Path=State_SelectedFilter}" Value="0">
                                                                    <Setter Property="Margin" Value="10,-32,0,0" />
                                                                    <Setter Property="Height" Value="32" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Path=IsLoading}" Value="True">
                                                                    <Setter Property="IsEnabled" Value="False" />
                                                                    <Setter Property="ToolTip" Value="{DynamicResource Tooltip_CannotFilter}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <ContentPresenter>
                                                        <ContentPresenter.Content>
                                                            <Grid>
                                                                <Image Source="Images/CustomInfinityBlueIcon.png" Height="16" />
                                                                <Border>
                                                                    <Border.Style>
                                                                        <Style TargetType="{x:Type Border}">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Setter Property="Background" Value="#80000000" />
                                                                            <Setter Property="Width" Value="38" />
                                                                            <Setter Property="Height" Value="28" />
                                                                            <Setter Property="CornerRadius" Value="2,2,0,0" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Path=IsLoading}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                </Border>
                                                            </Grid>
                                                        </ContentPresenter.Content>
                                                    </ContentPresenter>
                                                </Button>
                                                <Button x:Name="button_FilterAllForeground" ToolTip="{DynamicResource All}" Margin="10,-32,0,0" FontSize="30">
                                                    <Button.Style>
                                                        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource CustomButtonFilterSelected}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Path=State_SelectedFilter}" Value="0">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <ContentPresenter>
                                                        <ContentPresenter.Content>
                                                            <Image Source="Images/CustomInfinityBlueIcon.png" Height="16" Margin="0,0,0,4" />
                                                        </ContentPresenter.Content>
                                                    </ContentPresenter>
                                                </Button>

                                                <Button x:Name="button_FilterSims3Packs" Click="OnFilter">
                                                    <Button.Style>
                                                        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource CustomButtonFilter}">
                                                            <Setter Property="Margin" Value="52,-30,0,0" />
                                                            <Setter Property="ToolTip" Value="{DynamicResource Sims3Packs}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Path=State_SelectedFilter}" Value="1">
                                                                    <Setter Property="Margin" Value="52,-32,0,0" />
                                                                    <Setter Property="Height" Value="32" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Path=IsLoading}" Value="True">
                                                                    <Setter Property="IsEnabled" Value="False" />
                                                                    <Setter Property="ToolTip" Value="{DynamicResource Tooltip_CannotFilter}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <ContentPresenter>
                                                        <ContentPresenter.Content>
                                                            <Grid>
                                                                <Image Source="Images/CustomPlumbobBlueIcon.png" Height="25" />
                                                                <Border>
                                                                    <Border.Style>
                                                                        <Style TargetType="{x:Type Border}">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Setter Property="Background" Value="#80000000" />
                                                                            <Setter Property="Width" Value="38" />
                                                                            <Setter Property="Height" Value="28" />
                                                                            <Setter Property="CornerRadius" Value="2,2,0,0" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Path=IsLoading}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                </Border>
                                                            </Grid>
                                                        </ContentPresenter.Content>
                                                    </ContentPresenter>
                                                </Button>
                                                <Button x:Name="button_FilterSims3PacksForeground" ToolTip="{DynamicResource Sims3Packs}" Margin="52,-32,0,0">
                                                    <Button.Style>
                                                        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource CustomButtonFilterSelected}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Path=State_SelectedFilter}" Value="1">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <ContentPresenter>
                                                        <ContentPresenter.Content>
                                                            <Image Source="Images/CustomPlumbobBlueIcon.png" Height="25" Margin="0,0,0,4" />
                                                        </ContentPresenter.Content>
                                                    </ContentPresenter>
                                                </Button>

                                                <Button x:Name="button_FilterPackages" Click="OnFilter">
                                                    <Button.Style>
                                                        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource CustomButtonFilter}">
                                                            <Setter Property="Margin" Value="94,-30,0,0"/>
                                                            <Setter Property="ToolTip" Value="{DynamicResource Packages}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Path=State_SelectedFilter}" Value="2">
                                                                    <Setter Property="Margin" Value="94,-32,0,0"/>
                                                                    <Setter Property="Height" Value="32"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Path=IsLoading}" Value="True">
                                                                    <Setter Property="IsEnabled" Value="False"/>
                                                                    <Setter Property="ToolTip" Value="{DynamicResource Tooltip_CannotFilter}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <ContentPresenter>
                                                        <ContentPresenter.Content>
                                                            <Grid>
                                                                <Image Source="Images/CustomPackageBlueIcon.png" Height="22" />
                                                                <Border>
                                                                    <Border.Style>
                                                                        <Style TargetType="{x:Type Border}">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Setter Property="Background" Value="#80000000" />
                                                                            <Setter Property="Width" Value="38" />
                                                                            <Setter Property="Height" Value="28" />
                                                                            <Setter Property="CornerRadius" Value="2,2,0,0" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Path=IsLoading}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                </Border>
                                                            </Grid>
                                                        </ContentPresenter.Content>
                                                    </ContentPresenter>
                                                </Button>
                                                <Button x:Name="button_FilterPackagesForeground" ToolTip="{DynamicResource Packages}" Margin="94,-32,0,0">
                                                    <Button.Style>
                                                        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource CustomButtonFilterSelected}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Path=State_SelectedFilter}" Value="2">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <ContentPresenter>
                                                        <ContentPresenter.Content>
                                                            <Image Source="Images/CustomPackageBlueIcon.png" Height="22" Margin="0,0,0,4" />
                                                        </ContentPresenter.Content>
                                                    </ContentPresenter>
                                                </Button>

                                                <Button x:Name="button_SelectAll" Content="{DynamicResource Select_All}" Margin="10,10,0,0" Click="OnSelectAllOrNone">
                                                    <Button.Style>
                                                        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource CustomButtonRightPanel}">
                                                            <Setter Property="IsEnabled" Value="{Binding Path=DisplaysAnyFile}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Path=IsLoading}" Value="True">
                                                                    <Setter Property="IsEnabled" Value="False"/>
                                                                    <Setter Property="ToolTip" Value="{DynamicResource Tooltip_CannotSelectAll}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                                <Button x:Name="button_SelectNone" Content="{DynamicResource Select_None}" Margin="140,10,0,0" Click="OnSelectAllOrNone">
                                                    <Button.Style>
                                                        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource CustomButtonRightPanel}">
                                                            <Setter Property="IsEnabled" Value="{Binding Path=SelectedAnyFile}"/>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                                <Button x:Name="button_ExpandAll" Content="{DynamicResource Expand_All}" Margin="10,35,0,0" Click="OnExpandOrCollapseAll">
                                                    <Button.Style>
                                                        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource CustomButtonRightPanel}">
                                                            <Setter Property="IsEnabled" Value="{Binding Path=DisplaysAnyExpandableFile}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Path=IsLoading}" Value="True">
                                                                    <Setter Property="IsEnabled" Value="False"/>
                                                                    <Setter Property="ToolTip" Value="{DynamicResource Tooltip_CannotExpandAll}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
