                                                <StackPanel Orientation="Vertical">
                                                    <Label FontSize="18" Margin="-5,-8,0,2" Content="{DynamicResource Legal_Notice}" Foreground="{StaticResource CustomForegroundDarkBlue_Colour}" FontWeight="DemiBold" Height="33" VerticalAlignment="Top" HorizontalAlignment="Left" Width="400" />
                                                    <TextBlock Margin="0,0,0,0" FontSize="15" TextWrapping="WrapWithOverflow" Text="{DynamicResource Legal_Notice_Text}" Foreground="Navy" VerticalAlignment="Top" />
                                                </StackPanel>
                                            </Border>

                                            <Border BorderBrush="{StaticResource CustomForegroundDarkBlue_Colour}" BorderThickness="2" Margin="5,8" Padding="5" VerticalAlignment="Top" Background="{StaticResource CustomBackgroundVeryLightBlue_Colour}">
                                                <StackPanel Orientation="Vertical">
                                                    <Label FontSize="18" Margin="-5,-8,0,2" Content="{DynamicResource Special_Thanks}" Foreground="{StaticResource CustomForegroundDarkBlue_Colour}" FontWeight="DemiBold" Height="33" VerticalAlignment="Top" HorizontalAlignment="Left" Width="400" />
                                                    <TextBlock FontSize="15" TextWrapping="WrapWithOverflow" Text="{DynamicResource Special_Thanks_Text}" Foreground="Navy" VerticalAlignment="Top"/>
                                                    <TextBlock Margin="0,10,0,0" FontSize="15" TextWrapping="WrapWithOverflow" Text="{DynamicResource Special_Thanks_Text_Part2}" Foreground="Navy" VerticalAlignment="Top" />
                                                </StackPanel>
                                            </Border>

                                        </StackPanel>
                                    </ScrollViewer>

                                </Border>
                            </Border>
                        </Border>

                    </TabItem>
                    <TabItem>
                        <TabItem.Style>
                            <Style TargetType="{x:Type TabItem}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type TabItem}">
                                            <Border BorderThickness="1,0,1,0" BorderBrush="Black" Background="Transparent">
                                                <Border Name="Border" Style="{StaticResource CustomBorderTabItemMiddle}" MouseLeftButtonDown="OnMoveWindow">
                                                    <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="0" RecognizesAccessKey="True"/>
                                                </Border>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabItem.Style>
                        <TabItem.Header>
                            <Button x:Name="button_Settings" Content="{DynamicResource Settings}" Click="OnPanelButtonClick" Style="{StaticResource CustomButtonTabItemHeader}" />
                        </TabItem.Header>

                        <Border BorderThickness="1" BorderBrush="Black" Margin="10,0,18,18" CornerRadius="12" Background="Transparent">
                            <Border Style="{StaticResource CustomBorderTabItemContent}">
                                <Border BorderBrush="Transparent" BorderThickness="0" CornerRadius="8" MouseEnter="General_OnMouseEnter" MouseLeftButtonDown="PreventAnyAction" Background="{StaticResource CustomBackgroundLightBlue_Colour}">
                                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Margin="0">
                                        <ScrollViewer.Style>
                                            <Style TargetType="{x:Type ScrollViewer}">
                                                <EventSetter Event="PreviewMouseWheel" Handler="OnMouseWheel" />
                                            </Style>
                                        </ScrollViewer.Style>
                                        <StackPanel Orientation="Vertical">
                                            <Label Content="{DynamicResource Settings}" Style="{StaticResource CustomLabelMenuTitle}" />
                                            <Border Style="{StaticResource CustomBorderUnderline}" />
                                            <Border BorderBrush="{StaticResource CustomForegroundDarkBlue_Colour}" BorderThickness="2" Margin="5,8,5,0" Background="{StaticResource CustomBackgroundVeryLightBlue_Colour}" Padding="5">
                                                <StackPanel Orientation="Vertical">
                                                    <Label Margin="-5,-8,0,2" FontSize="18" Content="{DynamicResource Sims_3_User_Files_Directory}" Foreground="{StaticResource CustomForegroundDarkBlue_Colour}" FontWeight="DemiBold" VerticalAlignment="Top" HorizontalAlignment="Left" />
                                                    <TextBox Margin="10,0" Height="20" MinWidth="480" VerticalAlignment="Top" IsReadOnly="True">
                                                        <TextBox.Style>
                                                            <Style TargetType="{x:Type TextBox}">
                                                                <Setter Property="Text" Value="{Binding Path=Sims3UserFilesDir}" />
                                                            </Style>
                                                        </TextBox.Style>
                                                    </TextBox>
                                                    <Button x:Name="button_EditSims3UserFilesDir" Content="{DynamicResource Edit}" Margin="10,10,0,5" Click="OnEditSims3UserFilesDir" Style="{StaticResource CustomButtonRightPanel}" />
                                                </StackPanel>
                                            </Border>

                                            <Border BorderBrush="{StaticResource CustomForegroundDarkBlue_Colour}" BorderThickness="2" Margin="5,10,5,0" Padding="5" Background="{StaticResource CustomBackgroundVeryLightBlue_Colour}">
                                                <StackPanel Orientation="Vertical">
                                                    <Label Margin="-5,-8,0,2" FontSize="18" Content="{DynamicResource Language}" Foreground="{StaticResource CustomForegroundDarkBlue_Colour}" FontWeight="DemiBold" VerticalAlignment="Top" HorizontalAlignment="Left" />
                                                    <ComboBox Margin="10,0,10,5" VerticalAlignment="Top" VerticalContentAlignment="Center" ItemsSource="{Binding Languages}" SelectedItem="{Binding CurrLang}" SelectionChanged="OnChangeLanguage">
                                                        <ComboBox.Style>
                                                            <Style TargetType="ComboBox">
                                                                <Setter Property="ItemTemplate">
                                                                    <Setter.Value>
                                                                        <DataTemplate>
                                                                            <ComboBoxItem Content="{Binding Name}" IsHitTestVisible="False" />
                                                                        </DataTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </ComboBox.Style>
                                                    </ComboBox>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>
                            </Border>
                        </Border>

                    </TabItem>
                    <TabItem Focusable="False">
                        <TabItem.Style>
                            <Style TargetType="{x:Type TabItem}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type TabItem}">
                                            <Border BorderThickness="1,0,1,0" BorderBrush="Black" Background="Transparent">
                                                <Border Height="{Binding ElementName=TabItemHeaderFillingHeight, Path=ActualHeight}" Name="Border" Style="{StaticResource CustomBorderTabItemMiddleFilling}" MouseLeftButtonDown="OnMoveWindow">
                                                    <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" RecognizesAccessKey="True" />
                                                </Border>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabItem.Style>
                        <TabItem.Header>
                            <Separator Visibility="Hidden" />
                        </TabItem.Header>
                    </TabItem>
                    <TabItem Focusable="False">
                        <TabItem.Style>
                            <Style TargetType="{x:Type TabItem}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type TabItem}">
                                            <Border BorderThickness="1,0,1,1" BorderBrush="Black" Background="Transparent" CornerRadius="0,0,12,12">
                                                <Border Name="Border" Style="{StaticResource CustomBorderTabItemBottom}" MouseLeftButtonDown="OnMoveWindow" >
                                                    <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="0" RecognizesAccessKey="True"/>
                                                </Border>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabItem.Style>
                        <TabItem.Header>
                            <StackPanel>
                                <Label x:Name="label_Version" Content="{DynamicResource Version}" ToolTip="{DynamicResource Version_Tooltip}" HorizontalAlignment="Center" Margin="0,18,0,0" Width="180" HorizontalContentAlignment="Center" Foreground="{StaticResource CustomForegroundDarkBlue_Colour}" FontWeight="DemiBold" FontSize="13" Height="28" VerticalAlignment="Bottom" />
                                <Label x:Name="label_Versionnumber" Content="0.1.1.1" HorizontalAlignment="Center" Margin="0,-13,0,0" Width="180" HorizontalContentAlignment="Center" Foreground="{StaticResource CustomForegroundDarkBlue_Colour}" FontWeight="DemiBold" FontSize="13" Height="28" VerticalAlignment="Bottom" IsHitTestVisible="False" />
                            </StackPanel>
                        </TabItem.Header>
                    </TabItem>

                </TabControl>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Grid.Row="0" Background="Transparent" MouseLeave="BorderAll_OnMouseLeave" MouseEnter="BorderHorizontal_OnMouseEnter" MouseLeftButtonDown="WindowResizeNorth" />
        <Border Grid.Column="0" Grid.Row="1" Background="Transparent" MouseLeave="BorderAll_OnMouseLeave" MouseEnter="BorderVertical_OnMouseEnter" MouseLeftButtonDown="WindowResizeWest" />
        <Border Grid.Column="2" Grid.Row="1" Background="Transparent" MouseLeave="BorderAll_OnMouseLeave" MouseEnter="BorderVertical_OnMouseEnter" MouseLeftButtonDown="WindowResizeEast" />
        <Border Grid.Column="1" Grid.Row="2" Background="Transparent" MouseLeave="BorderAll_OnMouseLeave" MouseEnter="BorderHorizontal_OnMouseEnter" MouseLeftButtonDown="WindowResizeSouth" />
        <Border Grid.Column="0" Grid.Row="0" Background="Transparent" MouseLeave="BorderAll_OnMouseLeave" MouseEnter="BorderNorthWest_OnMouseEnter" MouseLeftButtonDown="WindowResizeNorthWest" Margin="0,0,-5,-5" />
        <Border Grid.Column="2" Grid.Row="0" Background="Transparent" MouseLeave="BorderAll_OnMouseLeave" MouseEnter="BorderNorthEast_OnMouseEnter" MouseLeftButtonDown="WindowResizeNorthEast" Margin="-5,0,0,-5" />
        <Border Grid.Column="0" Grid.Row="2" Background="Transparent" MouseLeave="BorderAll_OnMouseLeave" MouseEnter="BorderSouthWest_OnMouseEnter" MouseLeftButtonDown="WindowResizeSouthWest" Margin="0,-5,-5,0" />
        <Border Grid.Column="2" Grid.Row="2" Background="Transparent" MouseLeave="BorderAll_OnMouseLeave" MouseEnter="BorderSouthEast_OnMouseEnter" MouseLeftButtonDown="WindowResizeSouthEast" Margin="-5,-5,0,0" />

    </Grid>
</Window>
