<Window x:Class="HFFS3CustomLauncher.InvisibleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HFFS3CustomLauncher"
        mc:Ignorable="d"
        Title="InvisibleWindow" Height="660" Width="865" MinHeight="600" MinWidth="800" MaxHeight="1080" MaxWidth="1920" WindowStyle="None" AllowsTransparency="True" Background="#00000000" Focusable="False" IsHitTestVisible="False" ShowInTaskbar="False">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="10" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="10" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="10" />
        </Grid.RowDefinitions>
        <Border x:Name="Border_Left" Grid.Column="1" Grid.Row="1" BorderBrush="Gray" Background="Transparent">
            <Border.Style>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="CornerRadius" Value="8"/>
                    <Setter Property="BorderThickness" Value="3,0,0,0" />
                </Style>
            </Border.Style>
        </Border>
        <Border x:Name="Border_Top" Grid.Column="1" Grid.Row="1" BorderBrush="Gray" Background="Transparent">
            <Border.Style>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="CornerRadius" Value="8"/>
                    <Setter Property="BorderThickness" Value="0,3,0,0" />
                </Style>
            </Border.Style>
        </Border>
        <Border x:Name="Border_Right" Grid.Column="1" Grid.Row="1" BorderBrush="Gray" Background="Transparent">
            <Border.Style>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="CornerRadius" Value="8"/>
                    <Setter Property="BorderThickness" Value="0,0,3,0" />
                </Style>
            </Border.Style>
        </Border>
        <Border x:Name="Border_Bottom" Grid.Column="1" Grid.Row="1" BorderBrush="Gray" Background="Transparent">
            <Border.Style>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="CornerRadius" Value="8"/>
                    <Setter Property="BorderThickness" Value="0,0,0,3" />
                </Style>
            </Border.Style>
        </Border>
    </Grid>
</Window>
