<Window x:Class="HFFS3CustomLauncher.InitializerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HFFS3CustomLauncher" d:DataContext="{d:DesignInstance Type=local:MainLogic}"
        mc:Ignorable="d"
        Title="{DynamicResource Initial_Setup}" Height="252" Width="507" WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True" Background="#00000000" MouseLeftButtonDown="OnMoveWindow" ResizeMode="NoResize">

    <Window.Resources>
        <Style TargetType="ToolTip" BasedOn="{StaticResource CustomTooltip}" />
    </Window.Resources>

    <Border Style="{StaticResource CustomBorderModalWindowOuter}">
        <DockPanel>
            <StackPanel Style="{StaticResource CustomStackPanelModalWindow}">
                <Button x:Name="button_InitYes" Content="{DynamicResource Yes_proceed}" Click="OnClickInitYes" Style="{StaticResource CustomButtonModalWindow}" />
                <Separator Margin="10,0,0,0" Visibility="Hidden" />
                <Button x:Name="button_InitNo" Content="{DynamicResource No_it_is}" Click="OnClickInitNo" Style="{StaticResource CustomButtonModalWindow}" />
                <Separator Margin="10,0,0,0" Visibility="Hidden" />
                <Button x:Name="button_InitExit" Content="{DynamicResource Exit}" Click="OnClickInitExit" Style="{StaticResource CustomButtonModalWindow}" />
            </StackPanel>
            <Border Style="{StaticResource CustomBorderModalWindowInner}">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="3" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel Orientation="Vertical">
                    <Label Content="{DynamicResource Initial_Setup}"  Style="{StaticResource CustomLabelModalWindowTitle}" />
                    <Border Style="{StaticResource CustomBorderUnderline}" />
                    <TextBlock Margin="10,10,10,0" Foreground="#FF404080" FontWeight="DemiBold" FontSize="15" TextWrapping="WrapWithOverflow" Text="{DynamicResource Is_this_your_Sims_3_User_Files_Directory}" />
                    <TextBlock Margin="10,0" Foreground="#FF404080" FontWeight="DemiBold" FontSize="15" TextWrapping="WrapWithOverflow" Text="{DynamicResource The_directory_where_all_your_personal_Sims_3_data_is_stored}" />
                    <TextBlock Margin="10,10,10,0" Height="75" Width="460" TextWrapping="Wrap" TextAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="Text" Value="{Binding Path=Sims3UserFilesDir}"/>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>
        </DockPanel>
    </Border>
</Window>
